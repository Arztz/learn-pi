---
// Sidebar Component - Navigation with collapsible modules
---

<nav class="sidebar" id="sidebar" role="navigation" aria-label="Chapter navigation">
  <div class="sidebar-header">
    <a href="/docs/superpowers/" class="sidebar-title">
      <span class="sidebar-logo">◉</span>
      <span>Pi Learning Guide</span>
    </a>
  </div>

  <div class="sidebar-content">
    <!-- Module 1: Getting Started -->
    <div class="module" data-module="1">
      <button class="module-header" aria-expanded="true" aria-controls="module-1-chapters">
        <span class="module-arrow">▼</span>
        <span class="module-number">01</span>
        <span class="module-title">Getting Started</span>
      </button>
      <ul class="chapter-list" id="module-1-chapters">
        <li><a href="/docs/superpowers/chapters/module-1/0-what-is-pi" class="chapter-link" data-chapter="1-0"><span class="chapter-number">01</span><span class="chapter-name">What is pi?</span></a></li>
        <li><a href="/docs/superpowers/chapters/module-1/1-install" class="chapter-link" data-chapter="1-1"><span class="chapter-number">02</span><span class="chapter-name">Install in 5 minutes</span></a></li>
        <li><a href="/docs/superpowers/chapters/module-1/2-hello-pi" class="chapter-link" data-chapter="1-2"><span class="chapter-number">03</span><span class="chapter-name">Hello, pi!</span></a></li>
      </ul>
    </div>

    <!-- Module 2: Core Workflow -->
    <div class="module" data-module="2">
      <button class="module-header" aria-expanded="true" aria-controls="module-2-chapters">
        <span class="module-arrow">▼</span>
        <span class="module-number">02</span>
        <span class="module-title">Core Workflow</span>
      </button>
      <ul class="chapter-list" id="module-2-chapters">
        <li><a href="/docs/superpowers/chapters/module-2/3-reading-files" class="chapter-link" data-chapter="2-3"><span class="chapter-number">04</span><span class="chapter-name">Reading files</span></a></li>
        <li><a href="/docs/superpowers/chapters/module-2/4-writing-editing" class="chapter-link" data-chapter="2-4"><span class="chapter-number">05</span><span class="chapter-name">Writing & editing</span></a></li>
        <li><a href="/docs/superpowers/chapters/module-2/5-bash" class="chapter-link" data-chapter="2-5"><span class="chapter-number">06</span><span class="chapter-name">Bash commands</span></a></li>
        <li><a href="/docs/superpowers/chapters/module-2/6-sessions" class="chapter-link" data-chapter="2-6"><span class="chapter-number">07</span><span class="chapter-name">Sessions</span></a></li>
        <li><a href="/docs/superpowers/chapters/module-2/7-branching" class="chapter-link" data-chapter="2-7"><span class="chapter-number">08</span><span class="chapter-name">Branching & forks</span></a></li>
      </ul>
    </div>

    <!-- Module 3: Extending pi -->
    <div class="module" data-module="3">
      <button class="module-header" aria-expanded="true" aria-controls="module-3-chapters">
        <span class="module-arrow">▼</span>
        <span class="module-number">03</span>
        <span class="module-title">Extending pi</span>
      </button>
      <ul class="chapter-list" id="module-3-chapters">
        <li><a href="/docs/superpowers/chapters/module-3/8-extensions-intro" class="chapter-link" data-chapter="3-8"><span class="chapter-number">09</span><span class="chapter-name">Extensions intro</span></a></li>
        <li><a href="/docs/superpowers/chapters/module-3/9-first-tool" class="chapter-link" data-chapter="3-9"><span class="chapter-number">10</span><span class="chapter-name">Your first tool</span></a></li>
        <li><a href="/docs/superpowers/chapters/module-3/10-commands-events" class="chapter-link" data-chapter="3-10"><span class="chapter-number">11</span><span class="chapter-name">Commands & events</span></a></li>
        <li><a href="/docs/superpowers/chapters/module-3/11-event-bus-intro" class="chapter-link" data-chapter="3-11"><span class="chapter-number">12</span><span class="chapter-name">Event bus intro</span></a></li>
      </ul>
    </div>

    <!-- Advanced Topics (Always Expanded) -->
    <div class="module module-advanced" data-module="advanced">
      <button class="module-header" aria-expanded="true" aria-controls="advanced-chapters">
        <span class="module-arrow">▼</span>
        <span class="module-title">Advanced Topics</span>
      </button>
      <ul class="chapter-list" id="advanced-chapters">
        <li><a href="/docs/superpowers/chapters/module-a/1-agents-overview" class="chapter-link" data-chapter="a-1"><span class="chapter-number">A1</span><span class="chapter-name">Agent Teams</span></a></li>
        <li><a href="/docs/superpowers/chapters/module-a/2-single-agent" class="chapter-link" data-chapter="a-2"><span class="chapter-number">A2</span><span class="chapter-name">Agent Teams</span></a></li>
