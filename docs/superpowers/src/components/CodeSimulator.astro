---
// Code Simulator Component - Interactive pi interaction player

interface Props {
  script?: string;
  title?: string;
  showControls?: boolean;
}

const { script = '{}', title = 'pi Interaction', showControls = true } = Astro.props;
---

<div class="code-simulator" data-script={script} data-title={title}>
  <style>
    /* Inject simulator styles */
    .code-simulator { margin: var(--space-5) 0; }
  </style>

  <div class="simulator-header">
    <div class="header-left">
      <span class="simulator-title">{title}</span>
      <span class="language-badge">pi</span>
    </div>
    <div class="header-right">
      <button class="copy-btn" aria-label="Copy script" title="Copy script">
        <span>📋</span>
      </button>
      {showControls && (
        <button class="run-btn">
          <span class="run-icon">▶</span>
          <span>Run</span>
        </button>
      )}
    </div>
  </div>

  <div class="simulator-code">
    <pre><code class="language-typescript">{script}</code></pre>
  </div>

  {showControls && (
    <div class="output-container" id="outputContainer">
      <!-- Simulator output will be rendered here -->
    </div>
  )}
</div>

<script define:vars={{ script, showControls }}>
  // Dynamically load the pi simulator
  import '/src/assets/pi-simulator.js';

  document.addEventListener('DOMContentLoaded', () => {
    const simulatorEl = document.querySelector('.code-simulator');
    if (!simulatorEl) return;

    const outputContainer = simulatorEl.querySelector('#outputContainer') || simulatorEl.querySelector('.output-container');
    const runBtn = simulatorEl.querySelector('.run-btn');
    const copyBtn = simulatorEl.querySelector('.copy-btn');

    // Parse script
    let scriptData;
    try {
      scriptData = typeof script === 'string' ? JSON.parse(script) : script;
    } catch (e) {
      console.error('Failed to parse simulator script:', e);
      return;
    }

    // Create simulator instance when run is clicked
    if (runBtn && outputContainer) {
      runBtn.addEventListener('click', () => {
        if (!simulatorEl.simulator) {
          // Create style element for simulator CSS
          const styleEl = document.createElement('style');
          styleEl.textContent = simulatorCSS;
          document.head.appendChild(styleEl);

          // Create output element if not exists
          let outputEl = simulatorEl.querySelector('.simulator-output');
          if (!outputEl) {
            outputEl = document.createElement('div');
            outputEl.className = 'simulator-output';
            outputContainer.appendChild(outputEl);
          }

          simulatorEl.simulator = new PiSimulator(outputEl.parentElement, scriptData);
        } else {
          simulatorEl.simulator.play();
        }
      });
    }

    // Copy functionality
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        const scriptStr = typeof scriptData === 'string' ? scriptData : JSON.stringify(scriptData, null, 2);
        navigator.clipboard.writeText(scriptStr).then(() => {
          copyBtn.textContent = '✓';
          setTimeout(() => { copyBtn.innerHTML = '<span>📋</span>'; }, 2000);
        });
      });
    }
  });
</script>

<style>
  .code-simulator {
    margin: var(--space-5) 0;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: var(--bg-surface);
  }

  .simulator-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) var(--space-4);
    background-color: var(--bg-elevated);
    border-bottom: 1px solid var(--border-subtle);
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .simulator-title {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .language-badge {
    font-size: 0.6875rem;
    padding: var(--space-1) var(--space-2);
    background-color: var(--accent-subtle);
    color: var(--accent-primary);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    font-weight: 600;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .copy-btn {
    background: none;
    border: none;
    padding: var(--space-2);
    cursor: pointer;
    font-size: 0.875rem;
    opacity: 0.7;
    transition: opacity var(--transition-fast);
  }

  .copy-btn:hover {
    opacity: 1;
  }

  .run-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background-color: var(--accent-primary);
    border: none;
    border-radius: var(--radius-md);
    color: white;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color var(--transition-fast);
  }

  .run-btn:hover {
    background-color: var(--accent-hover);
  }

  .run-icon {
    font-size: 0.75rem;
  }

  .simulator-code {
    background-color: var(--bg-deep);
    padding: var(--space-4);
    overflow-x: auto;
  }

  .simulator-code pre {
    margin: 0;
    font-family: var(--font-code);
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--text-primary);
  }

  .simulator-code code {
    background: none;
    padding: 0;
  }

  .output-container {
    border-top: 1px solid var(--border-subtle);
  }

  /* Syntax highlighting */
  .simulator-code :global(.keyword) { color: var(--accent-primary); }
  .simulator-code :global(.string) { color: var(--success); }
  .simulator-code :global(.number) { color: var(--warning); }
  .simulator-code :global(.comment) { color: var(--text-muted); }
</style>