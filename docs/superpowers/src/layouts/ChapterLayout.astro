---
// Chapter Layout - Main layout for all chapter pages
import Sidebar from '../components/Sidebar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  moduleName: string;
  chapterNumber: number;
  readingTime?: string;
  description?: string;
  prevChapter?: { title: string; href: string };
  nextChapter?: { title: string; href: string };
}

const {
  title,
  moduleName,
  chapterNumber,
  readingTime = '5 min read',
  description = '',
  prevChapter,
  nextChapter
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | Pi Learning Guide</title>
  <meta name="description" content={description}>
</head>
<body>
  <!-- Sidebar (desktop) -->
  <Sidebar />

  <!-- Mobile Header -->
  <header class="mobile-header" id="mobileHeader">
    <button class="hamburger" id="hamburgerBtn" aria-label="Open menu" aria-expanded="false">
      <span class="hamburger-icon">☰</span>
    </button>
    <span class="mobile-title">{moduleName} • Chapter {chapterNumber}</span>
    <div class="mobile-nav">
      {prevChapter && <a href={prevChapter.href} class="mobile-nav-btn prev" aria-label="Previous chapter">◀</a>}
      {nextChapter && <a href={nextChapter.href} class="mobile-nav-btn next" aria-label="Next chapter">▶</a>}
    </div>
  </header>

  <!-- Sidebar backdrop (mobile) -->
  <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

  <!-- Main Content -->
  <main class="main-content">
    <article class="chapter">
      <!-- Chapter Header -->
      <header class="chapter-header">
        <div class="chapter-meta">
          <span class="module-badge">{moduleName}</span>
          <span class="separator">•</span>
          <span class="chapter-label">Chapter {chapterNumber}</span>
          <span class="separator">•</span>
          <span class="reading-time">{readingTime}</span>
        </div>
        <h1 class="chapter-title">{title}</h1>
        {description && <p class="chapter-description">{description}</p>}
        <div class="progress-bar">
          <div class="progress-fill" style="width: 33%"></div>
        </div>
      </header>

      <!-- Chapter Content -->
      <div class="chapter-content">
        <slot />
      </div>

      <!-- Chapter Navigation -->
      <nav class="chapter-nav" aria-label="Chapter navigation">
        <div class="nav-item nav-prev">
          {prevChapter ? (
            <a href={prevChapter.href} class="nav-link">
              <span class="nav-arrow">◀</span>
              <div class="nav-info">
                <span class="nav-label">Previous</span>
                <span class="nav-title">{prevChapter.title}</span>
              </div>
            </a>
          ) : <div></div>}
        </div>
        <div class="nav-item nav-next">
          {nextChapter ? (
            <a href={nextChapter.href} class="nav-link">
              <div class="nav-info">
                <span class="nav-label">Next</span>
                <span class="nav-title">{nextChapter.title}</span>
              </div>
              <span class="nav-arrow">▶</span>
            </a>
          ) : <div></div>}
        </div>
      </nav>
    </article>
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <p>Pi Learning Guide • Learn pi from Zero to Hero</p>
  </footer>
</body>
</html>

<style>
  /* Layout */
  .main-content {
    margin-left: var(--sidebar-width);
    min-height: 100vh;
    padding: var(--space-8);
    padding-top: var(--space-10);
  }

  .chapter {
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  /* Mobile Header (hidden on desktop) */
  .mobile-header {
    display: none;
  }

  @media (max-width: 767px) {
    .main-content {
      margin-left: 0;
      padding: calc(56px + var(--space-4)) var(--space-4) var(--space-4);
    }

    .mobile-header {
      display: flex;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 56px;
      background-color: var(--bg-surface);
      border-bottom: 1px solid var(--border-subtle);
      padding: 0 var(--space-4);
      align-items: center;
      justify-content: space-between;
      z-index: 99;
    }

    .hamburger {
      background: none;
      border: none;
      font-size: 1.25rem;
      color: var(--text-secondary);
      cursor: pointer;
      padding: var(--space-2);
    }

    .mobile-title {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .mobile-nav {
      display: flex;
      gap: var(--space-2);
    }

    .mobile-nav-btn {
      background: none;
      border: none;
      font-size: 1rem;
      color: var(--text-secondary);
      text-decoration: none;
      padding: var(--space-2);
    }

    .sidebar-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      background-color: rgba(15, 15, 35, 0.8);
      z-index: 99;
    }

    body.sidebar-open {
      overflow: hidden;
    }
  }

  /* Chapter Header */
  .chapter-header {
    padding-bottom: var(--space-6);
    margin-bottom: var(--space-6);
    border-bottom: 1px solid var(--border-subtle);
  }

  .chapter-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  .module-badge {
    color: var(--accent-primary);
    font-weight: 500;
  }

  .separator {
    color: var(--text-muted);
  }

  .chapter-title {
    margin-bottom: var(--space-4);
  }

  .chapter-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: var(--space-5);
  }

  .progress-bar {
    height: 4px;
    background-color: var(--border-subtle);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background-color: var(--accent-primary);
    transition: width var(--transition-base);
  }

  /* Chapter Content */
  .chapter-content {
    line-height: 1.7;
  }

  .chapter-content :global(h2) {
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }

  .chapter-content :global(h3) {
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }

  .chapter-content :global(p) {
    margin-bottom: var(--space-4);
    color: var(--text-secondary);
  }

  .chapter-content :global(pre) {
    margin: var(--space-5) 0;
  }

  .chapter-content :global(ul),
  .chapter-content :global(ol) {
    margin: var(--space-4) 0;
    padding-left: var(--space-6);
    color: var(--text-secondary);
  }

  .chapter-content :global(li) {
    margin-bottom: var(--space-2);
  }

  /* Chapter Navigation */
  .chapter-nav {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid var(--border-subtle);
  }

  .nav-item {
    flex: 1;
  }

  .nav-next {
    text-align: right;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    background-color: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--text-primary);
    transition: all var(--transition-fast);
  }

  .nav-link:hover {
    background-color: var(--bg-elevated);
    border-color: var(--border-active);
    text-decoration: none;
  }

  .nav-arrow {
    font-size: 1.25rem;
    color: var(--text-muted);
    transition: transform var(--transition-fast);
  }

  .nav-link:hover .nav-arrow {
    transform: translateX(-4px);
  }

  .nav-next .nav-link:hover .nav-arrow {
    transform: translateX(4px);
  }

  .nav-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .nav-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .nav-title {
    font-size: 0.875rem;
    font-weight: 500;
  }

  /* Site Footer */
  .site-footer {
    text-align: center;
    padding: var(--space-8);
    color: var(--text-muted);
    font-size: 0.875rem;
    border-top: 1px solid var(--border-subtle);
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .chapter-nav {
      flex-direction: column;
    }

    .nav-item {
      width: 100%;
    }

    .nav-next {
      text-align: left;
    }

    .nav-link {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>

<script>
  // Mobile sidebar toggle
  document.addEventListener('DOMContentLoaded', () => {
    const hamburgerBtn = document.getElementById('hamburgerBtn');
    const sidebar = document.getElementById('sidebar') || document.querySelector('.sidebar');
    const backdrop = document.getElementById('sidebarBackdrop');

    function openSidebar() {
      sidebar?.classList.add('open');
      backdrop?.classList.add('visible');
      hamburgerBtn?.setAttribute('aria-expanded', 'true');
      document.body.classList.add('sidebar-open');
    }

    function closeSidebar() {
      sidebar?.classList.remove('open');
      backdrop?.classList.remove('visible');
      hamburgerBtn?.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('sidebar-open');
    }

    hamburgerBtn?.addEventListener('click', () => {
      if (sidebar?.classList.contains('open')) {
        closeSidebar();
      } else {
        openSidebar();
      }
    });

    backdrop?.addEventListener('click', closeSidebar);
  });
</script>